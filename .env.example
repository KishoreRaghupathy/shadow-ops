# ==============================================================================
# Aegis-Ops Environment Template (.env.example)
# ==============================================================================
# Copy this file to '.env' in the root directory and populate with actual credentials.
# Do not commit the completed '.env' file to source control.

# Application Deployment Environment
ENV=development

# Structured Log Output Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Mandatory API Credentials (Raise SystemExit if missing or malformed)
GROQ_API_KEY=gsk_your_groq_api_key_placeholder
NOTION_TOKEN=secret_your_notion_integration_token_placeholder
NOTION_DATABASE_ID=your_notion_database_id_placeholder

# Tuning Parameters
MAX_CONCURRENT_PROBES=10
TIMEOUT_SECONDS=30
